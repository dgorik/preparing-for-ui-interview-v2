{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@course/styles": ["src/utils/styles.module.css"],
      "@course/cx": ["src/utils/utility.ts"],
      "@course/types": ["src/utils/types.ts"],
      "@course/utils": ["src/utils/utils.ts"]
    },
    "target": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["bun-types"],
    /* JSX */
    "jsx": "react-jsx",
    /* Emit */
    "noEmit": true,
    /* Interop */
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src"],
  "exclude": []
}
